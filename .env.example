# ==== Bağban AI — environment (copy to .env, fill real values; .env is NOT committed) ====
# Adapted from spec §26: NO Supabase — self-hosted Postgres + own JWT auth on Hetzner.

# ---- Database (Postgres 16 + PostGIS, self-hosted) ----
DATABASE_URL=postgresql://bagban:change-me@localhost:5432/bagban
POSTGRES_USER=bagban
POSTGRES_PASSWORD=change-me
POSTGRES_DB=bagban

# ---- Auth (own JWT, replaces Supabase Auth) ----
JWT_SECRET=change-me-to-a-long-random-hex   # openssl rand -hex 32
JWT_EXPIRES_HOURS=168
COOKIE_NAME=bagban_session

# ---- Backend / frontend URLs ----
BACKEND_BASE=http://localhost:8000
NEXT_PUBLIC_APP_URL=http://localhost:3000
INTERNAL_API_TOKEN=change-me   # n8n → backend /api/internal/* auth

# ---- Satellite (NASA HLS via Earthdata) ----
EARTHDATA_USERNAME=
EARTHDATA_PASSWORD=            # or use ~/.netrc
STAC_URL=https://cmr.earthdata.nasa.gov/stac/LPCLOUD
GDAL_DISABLE_READDIR_ON_OPEN=EMPTY_DIR
CPL_VSIL_CURL_ALLOWED_EXTENSIONS=.tif

# ---- Weather (Open-Meteo) ----
OPEN_METEO_BASE=https://api.open-meteo.com/v1
OPEN_METEO_API_KEY=            # only for commercial/self-host tier

# ---- AI (provider-agnostic adapter) ----
LLM_PROVIDER=                  # openai | anthropic | gemini | local
LLM_MODEL=
LLM_API_KEY=

# ---- Storage (local Hetzner volume now; S3-compatible later) ----
OBJECT_STORAGE_DRIVER=local
OBJECT_STORAGE_ROOT=./storage
OBJECT_STORAGE_BUCKET=bagban
TILE_SERVER_BASE=http://localhost:8000/api/tiles

# ---- Notifications (Phase 2) ----
TELEGRAM_BOT_TOKEN=
WHATSAPP_API_TOKEN=
SMS_PROVIDER_KEY=

# ---- Billing: DEFERRED (no payment yet). Kept for future:
# BILLING_PROVIDER=
# BILLING_WEBHOOK_SECRET=
